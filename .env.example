# Copy to .env and fill in. These keys are passed ONLY to the container.
# ── Required for /generate (real video) ──────────────────────────────────────
SEEDANCE_API_KEY=          # ByteDance Doubao Seedance 2.0 — billed per clip
ANTHROPIC_API_KEY=         # Sonnet executor + Opus advisor (storyboard)
# ── Optional ─────────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://127.0.0.1:8001   # how callers reach this service
FISH_AUDIO_API_KEY=        # TTS voiceover (optional; drama defaults tts=on)
CAPCUT_MATE_URL=           # only if using renderer=capcut
CAPCUT_API_KEY=            # only if using CapCut cloud render
CAPCUT_DRAFT_ROOT=         # local CapCut Drafts folder for renderer=capcut_draft
JIANYING_DRAFT_ROOT=       # local JianyingPro Drafts folder for renderer=jianying_draft
